# ───────────────────────────────────────
# ⚙️ PREFIX CONFIGURATION
# Put anything except @ (Ex: !, -, +, :, .  etc.).
# ───────────────────────────────────────
PREFIX=-

# ───────────────────────────────────────
# 👑 MODERATORS / OWNERS
# Put any phone number without + , () and spaces. Multiple numbers separated by commas.
# ───────────────────────────────────────
MODS=9181xxxxxxxx,9232xxxxxxxx

# ───────────────────────────────────────
# 🗄️ DATABASE
# Put your own MongoDB url, we will not provide you any public MongoDB url for stability.
# ───────────────────────────────────────
MONGODB=mongodb+srv://...put your MongoDB URL

# ───────────────────────────────────────
# 🔐 SESSION ID
# Put any random value and keep it copied. This acts as an identifier for the bot session.
# ───────────────────────────────────────
SESSION_ID=put any random string

# ───────────────────────────────────────
# 🤖 OPENAI API
# One or more OpenAI API keys (starts with sk-...).
# Separate multiple keys with commas — the bot picks one randomly each call.
# ───────────────────────────────────────
OPENAI_API=sk-key1,sk-key2,sk-key3

# ───────────────────────────────────────
# 🧠 CLAUDE API
# One or more Anthropic API keys to unlock official Claude features.
# Separate multiple keys with commas — the bot picks one randomly each call.
# ───────────────────────────────────────
CLAUDE_API=your-anthropic-key1,your-anthropic-key2

# ───────────────────────────────────────
# ✨ GEMINI API
# One or more Google Gemini API keys.
# Separate multiple keys with commas — the bot picks one randomly each call.
# ───────────────────────────────────────
GEMINI_API=your-gemini-key1,your-gemini-key2,your-gemini-key3

# ───────────────────────────────────────
# 🎬 TENOR API
# One or more Tenor API keys for GIF support.
# Separate multiple keys with commas — the bot picks one randomly each call.
# ───────────────────────────────────────
TENOR_API_KEY=AIzaSy-key1,AIzaSy-key2

# ───────────────────────────────────────
# 🏷️ STICKER PACK DETAILS
# Customize your sticker creator details
# ───────────────────────────────────────
PACKNAME=Atlas Bot
AUTHOR=by: Team Atlas

# ───────────────────────────────────────
# 🌐 SERVER PORT
# Put any port you want (Recommended 10000 as it supports all platforms).
# ───────────────────────────────────────
PORT=10000

# ───────────────────────────────────────
# 🗑️ GARBAGE COLLECTION
# When to perform garbage collection and session sync in mongodb (Minutes)
# ───────────────────────────────────────
GC_INTERVAL_MINUTES=5